<view class="page">

  <view class="header">
    <view class="header-left">
      <text class="app-title">灵感笔记</text>
      <view class="stats-row">
        <text class="stats-pill">今日 {{todayCount}} · 本周 {{weekCount}}</text>
      </view>
    </view>
    <view class="icon-btn" bindtap="goProfile">
      <text class="icon-btn-text">⚙</text>
    </view>
  </view>

  <view class="input-bar">
    <text class="spark">✦</text>
    <input
      class="input-field"
      placeholder="粘贴链接或你的想法..."
      placeholder-class="input-placeholder"
      bindinput="onQuickInput"
      value="{{quickInput}}"
      confirm-type="done"
      bindconfirm="saveQuickItem"
    />
    <view class="input-actions">
      <view class="icon-action" bindtap="pasteFromClipboard">
        <text>⎘</text>
      </view>
      <view class="icon-action" bindtap="openVoice">
        <text>♪</text>
      </view>
      <view class="save-btn" bindtap="saveQuickItem">
        <text class="save-btn-text">+</text>
      </view>
    </view>
  </view>

  <view class="list">
    <view class="empty-state" wx:if="{{list.length === 0}}">
      <text class="empty-icon">✦</text>
      <text class="empty-text">还没有灵感，快开始记录吧</text>
    </view>

    <view
      class="card"
      wx:for="{{list}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <view class="platform-icon" style="background:{{item.platformBg}}">
        <text class="platform-emoji">{{item.platformEmoji}}</text>
      </view>
      <view class="card-body">
        <view class="card-top">
          <text class="card-title">{{item.title}}</text>
          <text class="card-time">{{item.timeStr}}</text>
        </view>
        <text class="card-desc">{{item.sourceUrl || item.notes || '暂无备注'}}</text>
        <view class="tags-row" wx:if="{{item.tags && item.tags.length}}">
          <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">#{{tag}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item nav-active">
      <text class="nav-icon">⌂</text>
      <text class="nav-label">首页</text>
    </view>
    <view class="nav-item" bindtap="goCategory">
      <text class="nav-icon">⊞</text>
      <text class="nav-label">分类</text>
    </view>
    <view class="nav-item" bindtap="goSearch">
      <text class="nav-icon">⊙</text>
      <text class="nav-label">搜索</text>
    </view>
    <view class="nav-item" bindtap="goProfile">
      <text class="nav-icon">◎</text>
      <text class="nav-label">我的</text>
    </view>
  </view>

</view>

page {
  background: #13142a;
  color: #fff;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* ─── Header ─── */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 56rpx 32rpx 16rpx;
}

.app-title {
  font-size: 64rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  letter-spacing: -1rpx;
}

.stats-row {
  margin-top: 12rpx;
}

.stats-pill {
  display: inline-block;
  background: #242545;
  color: #8a8d9f;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  background: #242545;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-btn-text {
  font-size: 34rpx;
  color: #8a8d9f;
}

/* ─── Input bar ─── */
.input-bar {
  margin: 20rpx 32rpx 28rpx;
  background: #242545;
  border-radius: 22rpx;
  padding: 22rpx 20rpx;
  display: flex;
  align-items: center;
}

.spark {
  color: #6c5ce7;
  font-size: 30rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  color: #fff;
  font-size: 28rpx;
  min-width: 0;
}

.input-placeholder {
  color: #4a4d6a;
}

.input-actions {
  display: flex;
  align-items: center;
  margin-left: 12rpx;
  gap: 10rpx;
}

.icon-action {
  width: 58rpx;
  height: 58rpx;
  background: #2e304f;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #8a8d9f;
}

.save-btn {
  width: 58rpx;
  height: 58rpx;
  background: #6c5ce7;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  margin-top: -4rpx;
}

/* ─── List ─── */
.list {
  padding: 0 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  color: #3a3c5a;
}

.empty-text {
  font-size: 28rpx;
  color: #4a4d6a;
}

/* ─── Card ─── */
.card {
  background: #242545;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
}

.platform-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.platform-emoji {
  font-size: 36rpx;
}

.card-body {
  flex: 1;
  min-width: 0;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  flex: 1;
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-time {
  font-size: 22rpx;
  color: #4a4d6a;
  flex-shrink: 0;
}

.card-desc {
  font-size: 24rpx;
  color: #8a8d9f;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  background: #2e304f;
  color: #8a8d9f;
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

/* ─── Bottom nav ─── */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #1a1b35;
  border-top: 1rpx solid #2a2b45;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.nav-icon {
  font-size: 42rpx;
  color: #4a4d6a;
  line-height: 1;
}

.nav-label {
  font-size: 20rpx;
  color: #4a4d6a;
}

.nav-active .nav-icon,
.nav-active .nav-label {
  color: #6c5ce7;
}

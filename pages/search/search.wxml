<view class="page">
  <view class="search-bar">
    <text class="search-icon">⊙</text>
    <input
      class="search-input"
      placeholder="搜索标题、想法、标签..."
      placeholder-class="ph"
      bindinput="onKeywordInput"
      value="{{keyword}}"
      focus="{{true}}"
    />
  </view>

  <view class="list" wx:if="{{keyword}}">
    <view class="result-count">找到 {{list.length}} 条</view>
    <view class="card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="card-title">{{item.title}}</view>
      <view class="card-meta">{{item.sourcePlatform}}</view>
      <view class="card-notes">{{item.notes || item.sourceUrl || '暂无备注'}}</view>
      <view class="tags-row" wx:if="{{item.tags && item.tags.length}}">
        <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">#{{tag}}</text>
      </view>
    </view>
    <view class="empty" wx:if="{{list.length === 0}}">没有找到相关灵感</view>
  </view>

  <view class="hint" wx:if="{{!keyword}}">输入关键词开始搜索</view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goHome">
      <text class="nav-icon">⌂</text>
      <text class="nav-label">首页</text>
    </view>
    <view class="nav-item" bindtap="goCategory">
      <text class="nav-icon">⊞</text>
      <text class="nav-label">分类</text>
    </view>
    <view class="nav-item nav-active">
      <text class="nav-icon">⊙</text>
      <text class="nav-label">搜索</text>
    </view>
    <view class="nav-item" bindtap="goProfile">
      <text class="nav-icon">◎</text>
      <text class="nav-label">我的</text>
    </view>
  </view>
</view>

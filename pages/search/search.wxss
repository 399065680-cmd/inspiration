page { background: #13142a; color: #fff; }

.page { padding: 32rpx 32rpx 140rpx; }

.search-bar { background: #242545; border-radius: 22rpx; padding: 20rpx 24rpx; display: flex; align-items: center; margin-bottom: 24rpx; }

.search-icon { font-size: 36rpx; color: #6c5ce7; margin-right: 14rpx; }

.search-input { flex: 1; color: #fff; font-size: 28rpx; }

.ph { color: #4a4d6a; }

.result-count { color: #4a4d6a; font-size: 24rpx; margin-bottom: 16rpx; }

.list { display: flex; flex-direction: column; gap: 16rpx; }

.card { background: #242545; border-radius: 18rpx; padding: 24rpx; }

.card-title { font-size: 30rpx; font-weight: 600; color: #fff; margin-bottom: 8rpx; }

.card-meta { font-size: 22rpx; color: #6c5ce7; margin-bottom: 8rpx; }

.card-notes { font-size: 24rpx; color: #8a8d9f; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 10rpx; }

.tags-row { display: flex; flex-wrap: wrap; gap: 8rpx; }

.tag { background: #2e304f; color: #8a8d9f; padding: 4rpx 16rpx; border-radius: 999rpx; font-size: 22rpx; }

.empty, .hint { text-align: center; color: #4a4d6a; padding: 80rpx 0; font-size: 28rpx; }

.bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; height: 110rpx; background: #1a1b35; border-top: 1rpx solid #2a2b45; display: flex; padding-bottom: env(safe-area-inset-bottom); }

.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4rpx; }

.nav-icon { font-size: 42rpx; color: #4a4d6a; line-height: 1; }

.nav-label { font-size: 20rpx; color: #4a4d6a; }

.nav-active .nav-icon, .nav-active .nav-label { color: #6c5ce7; }
